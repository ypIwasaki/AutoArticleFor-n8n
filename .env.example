# Local n8n runtime
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
GENERIC_TIMEZONE=Asia/Tokyo
TZ=Asia/Tokyo
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_RUNNERS_ENABLED=true

# Set this before using production credentials. Generate a long random value.
N8N_ENCRYPTION_KEY=change-me-before-production

# Optional future integrations. Keep real values in .env or n8n Credentials only.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NEWS_API_KEY=
SERPAPI_API_KEY=
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# n8n API sync. Keep N8N_API_KEY in .env only.
N8N_API_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_WORKFLOW_ID=
N8N_WORKFLOW_NAME=Daily Keyword News Summary
N8N_WORKFLOW_FILE=n8n/workflows/daily-keyword-news-summary.workflow.json

# Project path visible from the n8n runtime.
# npm/WSL default: /home/raimu/N8N/AutoArticleFor-n8n
# Docker default: /project
# PROJECT_ROOT=/home/raimu/N8N/AutoArticleFor-n8n
# PROJECT_ROOT=/project

# Allow n8n file nodes to write generated Markdown into this project.
N8N_RESTRICT_FILE_ACCESS_TO=/home/raimu/N8N/AutoArticleFor-n8n/content
